/* 搞杯喝的 - 冲煮流程 */
/* 设计：375x812，bg #FAF7F2，cornerRadius 24rpx */

.brew-page {
  height: 100vh;
  background-color: #FAF7F2;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  font-family: "PingFang SC", "HarmonyOS Sans SC", "MiSans", "Microsoft YaHei", sans-serif;
  font-weight: 600;
  --page-accent: #E8752A;
  --page-accent-dark: #C85D1D;
  --page-accent-light: #FFFAF6;
  --page-shadow: rgba(232, 117, 42, 0.18);
}

.brew-page nav-bar,
.brew-page step-indicator {
  display: block;
  flex-shrink: 0;
}

/* 步骤内容区 */
.step-content {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 0 40rpx;
  padding-top: 24rpx;
}

.recipe-step-content {
  height: 0;
  min-height: 0;
  padding-bottom: calc(220rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.equip-step-content {
  height: 0;
  min-height: 0;
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.plan-step-content {
  height: 0;
  min-height: 0;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.water-step-content {
  height: 0;
  min-height: 0;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.step-header {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 32rpx;
  padding: 24rpx 26rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-left: 8rpx solid var(--page-accent);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(45, 36, 32, 0.04);
}

.step-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2A211B;
  line-height: 1.25;
}

.step-desc {
  font-size: 26rpx;
  color: #7A6050;
}

/* === Step 1: 选豆子 === */
.bean-step-content {
  height: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-bottom: 24rpx;
}

.bean-step-content .step-header {
  flex-shrink: 0;
}

.lucky-bean-card {
  flex-shrink: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #3C1F10 0%, #6B4226 58%, #A67B5B 100%);
  border: 2rpx solid rgba(232, 184, 96, 0.74);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 26rpx rgba(60, 31, 16, 0.22);
}

.lucky-bean-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.lucky-bean-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #FFF4DE;
  line-height: 1.25;
}

.lucky-bean-desc {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 250, 246, 0.82);
  line-height: 1.35;
}

.lucky-bean-action {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background-color: #E8B860;
  color: #3C1F10;
  box-shadow: 0 6rpx 18rpx rgba(232, 184, 96, 0.24);
}

.lucky-bean-action text {
  color: inherit;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding-bottom: 8rpx;
  flex-shrink: 0;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #2A211B;
  margin-right: 16rpx;
  transition: all 0.3s;
}

.filter-tag.active {
  background-color: var(--page-accent-light);
  border-color: var(--page-accent);
  color: var(--page-accent-dark);
  box-shadow: 0 4rpx 18rpx var(--page-shadow);
}

.bean-list {
  flex: 1;
  height: 0;
  min-height: 0;
  max-height: none;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

.bean-list bean-card {
  display: block;
  margin-bottom: 16rpx;
}

.inline-empty {
  box-sizing: border-box;
  width: 100%;
  padding: 34rpx 24rpx;
  margin-bottom: 16rpx;
  text-align: center;
  background-color: #FFFFFF;
  border: 2rpx dashed #EDE5D8;
  border-radius: 22rpx;
}

.inline-empty text {
  font-size: 25rpx;
  color: #9A8577;
}

.finished-beans-card {
  width: 100%;
  box-sizing: border-box;
  margin-top: 8rpx;
  margin-bottom: 28rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-left: 8rpx solid #7A6050;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 22rpx rgba(45, 36, 32, 0.05);
}

.finished-beans-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
}

.finished-beans-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.finished-beans-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2A211B;
  line-height: 1.25;
}

.finished-beans-desc {
  font-size: 23rpx;
  color: #7A6050;
  line-height: 1.35;
}

.finished-beans-arrow {
  flex: 0 0 auto;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background-color: #F2ECE6;
  color: #7A6050;
  font-size: 23rpx;
  font-weight: 800;
}

.finished-beans-list {
  padding: 0 20rpx 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #9A8577;
}

.bean-empty-state {
  flex: 1;
  min-height: 0;
  justify-content: flex-start;
  padding: 64rpx 0 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #2A211B;
  line-height: 1.2;
}

.empty-action-cards {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.empty-action-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 24rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-left: 8rpx solid var(--page-accent);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(45, 36, 32, 0.06);
}

.empty-action-card.quick {
  background-color: #FFF8EC;
  border-color: #E8B860;
  border-left-color: #E8B860;
}

.empty-action-card.manual {
  background-color: #FFFFFF;
  border-color: #EDE5D8;
  border-left-color: var(--page-accent);
}

.empty-action-icon {
  flex: 0 0 auto;
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--page-accent);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.empty-action-card.quick .empty-action-icon {
  background-color: #E8B860;
  color: #3C1F10;
}

.empty-action-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.empty-action-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2A211B;
  line-height: 1.25;
}

.empty-action-desc {
  font-size: 23rpx;
  color: #7A6050;
  line-height: 1.35;
}

/* === Step 2: 选器具 === */
.equip-section {
  margin-bottom: 32rpx;
}

.equip-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2A211B;
  margin-bottom: 16rpx;
}

.equip-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s;
}

.equip-option.active {
  border-color: var(--page-accent);
  background-color: var(--page-accent-light);
  box-shadow: 0 6rpx 26rpx var(--page-shadow);
}

.equip-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #EDE5D8;
  background-color: #FFFFFF;
  flex-shrink: 0;
  transition: all 0.3s;
}

.equip-radio.checked {
  border-color: var(--page-accent);
  background-color: var(--page-accent);
  box-shadow: inset 0 0 0 6rpx #FFFFFF;
}

.equip-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.equip-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2A211B;
}

.equip-desc {
  font-size: 24rpx;
  color: #7A6050;
}

/* === Step 3: 定粉量 === */
.dose-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.dose-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.dose-card.active {
  border-color: var(--page-accent);
  background-color: var(--page-accent-light);
  box-shadow: 0 6rpx 26rpx var(--page-shadow);
}

.dose-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.dose-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #EDE5D8;
  background-color: #FFFFFF;
  flex-shrink: 0;
  transition: all 0.3s;
}

.dose-radio.checked {
  border-color: var(--page-accent);
  background-color: var(--page-accent);
  box-shadow: inset 0 0 0 6rpx #FFFFFF;
}

.dose-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A211B;
}

.dose-desc {
  font-size: 24rpx;
  color: #7A6050;
  padding-left: 60rpx;
}

/* === Step 4: 冲煮水 === */
.water-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.water-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 22rpx;
  transition: all 0.3s;
}

.water-card.active {
  border-color: var(--page-accent);
  background-color: var(--page-accent-light);
  box-shadow: 0 6rpx 26rpx var(--page-shadow);
}

.water-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #EDE5D8;
  background-color: #FFFFFF;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.water-radio.checked {
  border-color: var(--page-accent);
  background-color: var(--page-accent);
  box-shadow: inset 0 0 0 5rpx #FFFFFF;
}

.water-info {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.water-heading {
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.water-name {
  min-width: 0;
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #2A211B;
  line-height: 1.35;
  word-break: break-all;
}

.water-tds {
  flex-shrink: 0;
  max-width: 156rpx;
  box-sizing: border-box;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background-color: var(--page-accent-light);
  color: var(--page-accent-dark);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.water-desc {
  font-size: 23rpx;
  color: #7A6050;
  line-height: 1.5;
  word-break: break-all;
}

.tds-input-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 22rpx;
  margin-bottom: 32rpx;
}

.tds-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #2A211B;
}

.tds-input {
  width: 100%;
  box-sizing: border-box;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background-color: #FAF7F2;
  color: #2A211B;
  font-size: 30rpx;
  border: 2rpx solid #EDE5D8;
}

.tds-hint {
  font-size: 22rpx;
  color: #9A8577;
  line-height: 1.5;
  word-break: break-all;
}

.plan-options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.plan-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 32rpx 28rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.plan-card.active {
  border-color: var(--page-accent);
  background-color: var(--page-accent-light);
  box-shadow: 0 6rpx 26rpx var(--page-shadow);
}

.plan-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #EDE5D8;
  background-color: #FFFFFF;
  flex-shrink: 0;
  margin-top: 4rpx;
  transition: all 0.3s;
}

.plan-radio.checked {
  border-color: var(--page-accent);
  background-color: var(--page-accent);
  box-shadow: inset 0 0 0 6rpx #FFFFFF;
}

.plan-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.plan-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A211B;
}

.plan-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: #7A6050;
  word-break: break-all;
}

.classic-methods {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 28rpx;
}

.classic-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2A211B;
}

.classic-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.classic-card.active {
  border-color: var(--page-accent);
  background-color: var(--page-accent-light);
  box-shadow: 0 6rpx 26rpx var(--page-shadow);
}

.classic-radio {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 3rpx solid #EDE5D8;
  background-color: #FFFFFF;
  flex-shrink: 0;
  margin-top: 4rpx;
  transition: all 0.3s;
}

.classic-radio.checked {
  border-color: var(--page-accent);
  background-color: var(--page-accent);
  box-shadow: inset 0 0 0 5rpx #FFFFFF;
}

.classic-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.classic-heading {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.classic-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2A211B;
  line-height: 1.3;
  word-break: break-all;
}

.classic-difficulty {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  background-color: var(--page-accent-light);
  border-radius: 14rpx;
  font-size: 20rpx;
  color: var(--page-accent-dark);
}

.classic-summary,
.classic-meta {
  font-size: 23rpx;
  line-height: 1.45;
  color: #7A6050;
  word-break: break-all;
}

.classic-meta {
  color: var(--page-accent-dark);
  font-weight: 600;
}

/* === 底部操作区 === */
.bottom-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 12rpx 40rpx;
  padding-bottom: calc(18rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(250, 247, 242, 0.72) 0%, #FAF7F2 52%);
  flex-shrink: 0;
  box-sizing: border-box;
  margin-bottom: calc(124rpx + constant(safe-area-inset-bottom));
  margin-bottom: calc(124rpx + env(safe-area-inset-bottom));
}

.bottom-actions .btn-primary {
  flex: 1;
  height: 72rpx;
  padding: 0;
  background: linear-gradient(135deg, var(--page-accent) 0%, var(--page-accent-dark) 100%);
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 72rpx;
}

.bottom-actions .btn-primary[disabled] {
  opacity: 0.4;
}

.bottom-actions .btn-secondary {
  width: 168rpx;
  height: 72rpx;
  padding: 0;
  background-color: #FFFFFF;
  color: var(--page-accent-dark);
  font-size: 25rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: 2rpx solid var(--page-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 72rpx;
}
