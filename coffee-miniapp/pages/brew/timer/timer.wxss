.timer-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: calc(44rpx + constant(safe-area-inset-top)) 34rpx calc(36rpx + constant(safe-area-inset-bottom));
  padding: calc(44rpx + env(safe-area-inset-top)) 34rpx calc(36rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #E8752A 0%, #F3A15F 42%, #FAF7F2 100%);
  color: #2A211B;
  font-family: "PingFang SC", "HarmonyOS Sans SC", "MiSans", "Microsoft YaHei", sans-serif;
  font-weight: 700;
  display: flex;
  flex-direction: column;
}

.timer-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.nav-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 22rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.24);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 900;
}

.nav-btn::after,
.control-btn::after {
  border: 0;
}

.timer-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timer-title {
  font-size: 34rpx;
  color: #FFFFFF;
  line-height: 1.25;
  word-break: break-all;
  text-shadow: 0 3rpx 8rpx rgba(45, 36, 32, 0.18);
}

.timer-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.35;
  word-break: break-all;
}

.timer-main {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 22rpx;
  padding: 34rpx 0;
}

.stage-count {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 250, 246, 0.86);
  color: #9B4213;
  font-size: 23rpx;
  font-weight: 900;
}

.stage-name {
  font-size: 54rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1.15;
  text-align: center;
  word-break: break-all;
  text-shadow:
    2rpx 0 0 #2A211B,
    -2rpx 0 0 #2A211B,
    0 2rpx 0 #2A211B,
    0 -2rpx 0 #2A211B,
    2rpx 2rpx 0 #2A211B,
    -2rpx 2rpx 0 #2A211B,
    2rpx -2rpx 0 #2A211B,
    -2rpx -2rpx 0 #2A211B;
}

.time-panel {
  display: flex;
  gap: 18rpx;
}

.time-panel.single .time-block {
  width: 100%;
}

.time-block {
  flex: 1;
  min-width: 0;
  padding: 34rpx 22rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(237, 229, 216, 0.82);
  text-align: center;
}

.time-block.active {
  background-color: #2A211B;
  border-color: #2A211B;
}

.time-label {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #7A6050;
  line-height: 1.25;
  text-align: center;
}

.time-value {
  display: block;
  margin-top: 16rpx;
  font-size: 86rpx;
  font-weight: 900;
  color: #E8752A;
  line-height: 1;
  text-align: center;
}

.time-block.active .time-label,
.time-block.active .time-value {
  color: #FFFFFF;
}

.node-card,
.prompt-card {
  box-sizing: border-box;
  width: 100%;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(237, 229, 216, 0.90);
  box-shadow: 0 12rpx 30rpx rgba(45, 36, 32, 0.10);
}

.node-card {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
}

.node-item {
  flex: 1;
  min-width: 0;
}

.node-label,
.prompt-label {
  display: block;
  font-size: 22rpx;
  color: #7A6050;
  line-height: 1.3;
}

.node-value {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 900;
  color: #2A211B;
  line-height: 1.2;
  word-break: break-all;
}

.node-subvalue {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #E8752A;
  line-height: 1.2;
}

.prompt-card {
  padding: 26rpx;
  background-color: #FFF4DE;
  border-color: rgba(217, 154, 54, 0.36);
}

.prompt-text {
  display: block;
  margin-top: 14rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: #2A211B;
  line-height: 1.35;
  word-break: break-all;
}

.progress-wrap {
  width: 100%;
  box-sizing: border-box;
}

.progress-track {
  height: 14rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.46);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background-color: #3E9A5E;
  transition: width 180ms linear;
}

.progress-markers {
  position: relative;
  height: 44rpx;
  margin-top: 10rpx;
}

.progress-marker {
  position: absolute;
  top: 0;
  min-width: 58rpx;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.progress-marker.last {
  transform: translateX(-100%);
  align-items: flex-end;
}

.progress-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.74);
  border: 2rpx solid rgba(122, 96, 80, 0.18);
}

.progress-marker-label {
  display: block;
  padding: 3rpx 7rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.70);
  color: #7A6050;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
}

.progress-marker.active .progress-dot {
  background-color: #3E9A5E;
  border-color: #3E9A5E;
}

.progress-marker.active .progress-marker-label {
  background-color: #3E9A5E;
  color: #FFFFFF;
}

.finish-card {
  width: 100%;
  box-sizing: border-box;
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background-color: #3E9A5E;
  color: #FFFFFF;
  box-shadow: 0 12rpx 26rpx rgba(62, 154, 94, 0.24);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.finish-title {
  font-size: 28rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.90);
  line-height: 1.3;
}

.finish-action {
  font-size: 34rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1.2;
}

.empty-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 30rpx;
}

.timer-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: -28rpx;
  margin-bottom: 104rpx;
}

.timer-main-actions {
  display: flex;
  align-items: stretch;
  gap: 14rpx;
}

.control-btn {
  flex: 1;
  min-width: 0;
  width: auto;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  height: 92rpx;
  line-height: normal;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-btn.primary {
  background-color: #3E9A5E;
  color: #FFFFFF;
}

.control-btn.ghost {
  background-color: #FFFFFF;
  color: #E8752A;
  border: 2rpx solid rgba(232, 117, 42, 0.34);
}

.control-btn.reset {
  flex: none;
  width: 100%;
  background-color: rgba(255, 255, 255, 0.80);
  color: #7A6050;
  text-align: center;
}
