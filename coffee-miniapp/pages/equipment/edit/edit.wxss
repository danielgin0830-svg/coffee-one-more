/* 添加/编辑设备 */
/* 设计：375x812，bg #FAF7F2 */

.edit-equip-page {
  min-height: 100vh;
  background-color: #FAF7F2;
}

.form {
  padding: 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-group.row {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A211B;
}

.form-input {
  height: 88rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #2A211B;
}

.form-input:focus {
  border-color: #E8752A;
}

.form-picker {
  height: 88rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 20rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker-value {
  font-size: 28rpx;
  color: #2A211B;
  flex: 1;
  min-width: 0;
}

.form-picker-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 36rpx;
  color: #9A8577;
}

.form-hint {
  font-size: 22rpx;
  color: #7A6050;
  line-height: 1.5;
}

/* 保存按钮 - 抹茶绿，区别于下一步操作 */
.btn-save {
  width: 100%;
  height: 96rpx;
  background-color: #3E9A5E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}
