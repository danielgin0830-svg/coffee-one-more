.qr-import-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 56rpx;
  background-color: #FAF7F2;
}

.scan-band {
  margin: 28rpx 32rpx 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  background-color: #202522;
  border-left: 10rpx solid #E8752A;
  border-radius: 16rpx;
}

.scan-mark {
  flex-shrink: 0;
  width: 86rpx;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #E8752A;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 900;
}

.scan-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.scan-title {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.scan-subtitle {
  color: #C9CEC9;
  font-size: 22rpx;
  font-weight: 700;
}

.scan-actions {
  margin: 0 32rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.scan-button,
.preview-button {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  margin: 0;
  border-radius: 16rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.scan-button { height: 86rpx; }

.scan-button.primary,
.preview-button.primary {
  color: #FFFFFF;
  background-color: #E8752A;
  border: 0;
}

.scan-button.secondary,
.preview-button.secondary {
  color: #2A211B;
  background-color: #FFFFFF;
  border: 2rpx solid #D8D4CE;
}

.scan-empty {
  margin-top: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-code {
  position: relative;
  width: 244rpx;
  height: 244rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
}

.corner {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  border-color: #2F7848;
  border-style: solid;
}

.corner.top-left { top: 0; left: 0; border-width: 8rpx 0 0 8rpx; }
.corner.top-right { top: 0; right: 0; border-width: 8rpx 8rpx 0 0; }
.corner.bottom-left { bottom: 0; left: 0; border-width: 0 0 8rpx 8rpx; }

.empty-center {
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B95017;
  background-color: #FFF3E8;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-label {
  color: #7A6050;
  font-size: 26rpx;
  font-weight: 800;
}

.preview-card {
  width: calc(100% - 64rpx);
  box-sizing: border-box;
  margin: 26rpx 32rpx 0;
  padding: 28rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E1DDD6;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 28rpx rgba(45, 36, 32, 0.06);
}

.preview-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.preview-heading {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-kicker {
  color: #B95017;
  font-size: 23rpx;
  font-weight: 900;
}

.preview-title {
  color: #2A211B;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
  word-break: break-all;
}

.signature-badge {
  flex-shrink: 0;
  padding: 9rpx 13rpx;
  border-radius: 8rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.signature-badge.verified {
  color: #22623A;
  background-color: #EAF4ED;
  border: 2rpx solid #9FC9AC;
}

.signature-badge.pending {
  color: #805711;
  background-color: #FFF5D9;
  border: 2rpx solid #E2C36B;
}

.signature-badge.invalid {
  color: #9C2F26;
  background-color: #FCEAE7;
  border: 2rpx solid #E9AAA3;
}

.issuer-row {
  margin-top: 20rpx;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-top: 2rpx solid #EEEAE4;
  border-bottom: 2rpx solid #EEEAE4;
}

.issuer-label,
.batch-id {
  min-width: 0;
  color: #7A6050;
  font-size: 22rpx;
  font-weight: 800;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.preview-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.preview-item {
  min-width: 0;
  min-height: 104rpx;
  box-sizing: border-box;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 9rpx;
  background-color: #F6F7F4;
  border-left: 6rpx solid #2F7848;
}

.preview-item.wide { grid-column: 1 / -1; }

.item-label {
  color: #7A6050;
  font-size: 21rpx;
  font-weight: 800;
}

.item-value {
  color: #2A211B;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}

.flavor-item {
  border-left-color: #E8752A;
  background-color: #FFF8F1;
}

.flavor-value { font-weight: 800; line-height: 1.55; }

.invalid-notice {
  margin-top: 20rpx;
  padding: 18rpx;
  color: #9C2F26;
  background-color: #FCEAE7;
  border: 2rpx solid #E9AAA3;
  border-radius: 12rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.preview-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.preview-button { height: 86rpx; }
.preview-button[disabled] { opacity: 0.42; }
