/* 冲煮方案卡片 */
/* 设计：335xauto，bg #FFF，borderRadius 24rpx */
/* 内边距 32rpx，gap 24rpx */

.recipe-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #EDE5D8;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  font-family: "PingFang SC", "HarmonyOS Sans SC", "MiSans", "Microsoft YaHei", sans-serif;
  font-weight: 600;
}

.recipe-method,
.recipe-start-card,
.recipe-params,
.grinder-reference,
.recipe-stages,
.flavor-feedback,
.recipe-risks,
.recipe-actions {
  margin-top: 26rpx;
}

.recipe-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.recipe-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2A211B;
  flex: 1;
  min-width: 0;
  line-height: 1.25;
  word-break: break-all;
}

.recipe-bookmark {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #9A8577;
}

.recipe-bookmark.active {
  color: #E8752A;
}

.recipe-start-card {
  width: 100%;
  box-sizing: border-box;
  min-height: 112rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #E8752A 0%, #C85D1D 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 12rpx 26rpx rgba(232, 117, 42, 0.24);
}

.recipe-start-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recipe-start-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1.2;
}

.recipe-start-subtitle {
  font-size: 22rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.35;
}

.recipe-start-arrow {
  flex-shrink: 0;
  margin-left: 18rpx;
  font-size: 58rpx;
  font-weight: 900;
  color: #FFFFFF;
  line-height: 1;
}

.recipe-method {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 18rpx 20rpx;
  background-color: #FAF7F2;
  border-radius: 12rpx;
}

.method-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2A211B;
  line-height: 1.3;
  word-break: break-all;
}

.method-source {
  font-size: 22rpx;
  color: #7A6050;
}

/* 参数网格 2x2 */
.recipe-params {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: -18rpx;
}

.param-item {
  box-sizing: border-box;
  width: 48%;
  min-height: 138rpx;
  margin-bottom: 18rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 18rpx;
  padding: 20rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 8rpx 18rpx rgba(122, 96, 80, 0.08);
}

.param-label {
  font-size: 21rpx;
  font-weight: 700;
  color: #7A6050;
  line-height: 1.2;
}

.param-value {
  margin-top: 10rpx;
  font-size: 27rpx;
  font-weight: 900;
  color: #2A211B;
  line-height: 1.32;
  word-break: break-all;
}

.param-item:first-child {
  width: 48%;
  background-color: #FFFAF6;
  border-color: rgba(232, 117, 42, 0.42);
}

.grinder-reference {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx;
  background-color: #FAF7F2;
  border-radius: 12rpx;
  border-left: 6rpx solid #9A8577;
}

.grinder-text {
  font-size: 24rpx;
  color: #2A211B;
  line-height: 1.5;
  word-break: break-all;
}

.grinder-note {
  font-size: 22rpx;
  color: #7A6050;
  line-height: 1.5;
  word-break: break-all;
}

/* 注水阶段 */
.recipe-stages {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2A211B;
  margin-bottom: 4rpx;
}

.stage-item {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-left: 8rpx solid #E8752A;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(45, 36, 32, 0.04);
  margin-top: 14rpx;
}

.stage-index {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8752A 0%, #C85D1D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  box-shadow: 0 4rpx 12rpx rgba(232, 117, 42, 0.22);
}

.stage-index text {
  font-size: 24rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.stage-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.stage-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #2A211B;
  line-height: 1.3;
  word-break: break-all;
}

.bean-extra-reference {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 22rpx;
  background-color: #FFFAF6;
  border: 2rpx solid #EDE5D8;
  border-radius: 18rpx;
}

.bean-extra-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #7A6050;
  line-height: 1.55;
  word-break: break-all;
}

.stage-chip-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: -12rpx;
}

.stage-chip {
  max-width: 100%;
  box-sizing: border-box;
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.stage-chip-water {
  background-color: #FFFAF6;
  border-color: rgba(232, 117, 42, 0.34);
}

.stage-chip-time {
  background-color: #EEF7F1;
  border-color: rgba(62, 154, 94, 0.34);
}

.stage-chip-label {
  font-size: 21rpx;
  font-weight: 700;
  color: #7A6050;
  line-height: 1.2;
}

.stage-chip-value {
  font-size: 25rpx;
  font-weight: 800;
  color: #2A211B;
  line-height: 1.2;
  word-break: break-all;
}

.stage-chip-water .stage-chip-value {
  color: #C85D1D;
}

.stage-chip-time .stage-chip-value {
  color: #2F7848;
}

.stage-note-block {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  padding: 12rpx 14rpx;
  background-color: #FFF4DE;
  border: 2rpx solid rgba(217, 154, 54, 0.30);
  border-radius: 14rpx;
}

.stage-note-label {
  flex: 0 0 auto;
  font-size: 20rpx;
  font-weight: 800;
  color: #9B6420;
  line-height: 1.3;
  white-space: nowrap;
}

.stage-note-text {
  flex: 1;
  width: 100%;
  min-width: 0;
  font-size: 20rpx;
  color: #7A6050;
  line-height: 1.45;
  overflow: visible;
  text-overflow: clip;
  white-space: normal;
  word-break: break-all;
}

/* 风险提示 */
.recipe-risks {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 22rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(45, 36, 32, 0.04);
}

.risk-item {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  margin-top: 10rpx;
}

.risk-dot {
  color: #E8752A;
  font-weight: 700;
}

.risk-text {
  font-size: 24rpx;
  color: #7A6050;
  line-height: 1.6;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.flavor-feedback {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 26rpx;
  background: linear-gradient(135deg, #7A6050 0%, #A66F4A 100%);
  border: 2rpx solid rgba(232, 184, 96, 0.70);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(122, 96, 80, 0.16);
}

.feedback-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.feedback-section-title {
  color: #FFFFFF;
  text-shadow:
    1rpx 0 0 rgba(45, 36, 32, 0.65),
    -1rpx 0 0 rgba(45, 36, 32, 0.65),
    0 1rpx 0 rgba(45, 36, 32, 0.65),
    0 -1rpx 0 rgba(45, 36, 32, 0.65),
    0 2rpx 4rpx rgba(45, 36, 32, 0.28);
}

.feedback-subtitle {
  font-size: 23rpx;
  color: #FFFFFF;
  line-height: 1.5;
  text-shadow:
    1rpx 0 0 rgba(45, 36, 32, 0.65),
    -1rpx 0 0 rgba(45, 36, 32, 0.65),
    0 1rpx 0 rgba(45, 36, 32, 0.65),
    0 -1rpx 0 rgba(45, 36, 32, 0.65),
    0 2rpx 4rpx rgba(45, 36, 32, 0.24);
}

.bean-flavor-reference {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 20rpx;
  background-color: #FFFAF6;
  border: 2rpx solid rgba(232, 184, 96, 0.58);
  border-left: 10rpx solid #E8B860;
  border-radius: 16rpx;
  box-shadow: 0 5rpx 14rpx rgba(45, 36, 32, 0.10);
}

.bean-flavor-reference-label {
  font-size: 22rpx;
  font-weight: 900;
  color: #9B6420;
  line-height: 1.3;
}

.bean-flavor-reference-text {
  font-size: 25rpx;
  font-weight: 800;
  color: #2A211B;
  line-height: 1.5;
  word-break: break-all;
}

.feedback-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: -14rpx;
}

.feedback-chip {
  max-width: 100%;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  padding: 14rpx 22rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #2A211B;
  line-height: 1.3;
  box-shadow: 0 4rpx 10rpx rgba(122, 96, 80, 0.10);
  margin-right: 14rpx;
  margin-bottom: 14rpx;
}

.feedback-chip text {
  color: inherit;
}

.feedback-chip-good {
  background-color: #EEF7F1;
  border-color: #3E9A5E;
  color: #2F7848;
}

.feedback-chip-warning {
  background-color: #FFFAF6;
  border-color: #E8752A;
  color: #9B4213;
}

.feedback-chip-alert {
  background-color: #FFF4DE;
  border-color: #D99A36;
  color: #7A451D;
}

.feedback-chip-good.active {
  background-color: #3E9A5E;
  border-color: #3E9A5E;
  color: #FFFFFF;
}

.feedback-chip-warning.active {
  background-color: #E8752A;
  border-color: #E8752A;
  color: #FFFFFF;
}

.feedback-chip-alert.active {
  background-color: #7A451D;
  border-color: #7A451D;
  color: #FFFFFF;
}

.feedback-result {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background-color: #FFFBFA;
  border-radius: 14rpx;
  border: 2rpx solid #EDE5D8;
  box-shadow: 0 4rpx 12rpx rgba(122, 96, 80, 0.08);
}

.applied-feedback {
  background-color: #EEF7F1;
  border-color: rgba(62, 154, 94, 0.45);
  border-left: 10rpx solid #3E9A5E;
}

.current-feedback {
  background-color: #FFFAF6;
  border-color: rgba(232, 117, 42, 0.45);
  border-left: 10rpx solid #E8752A;
}

.next-feedback {
  background-color: #FFF4DE;
  border-color: rgba(217, 154, 54, 0.45);
  border-left: 10rpx solid #D99A36;
}

.feedback-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2A211B;
}

.feedback-text,
.feedback-note {
  font-size: 23rpx;
  color: #7A6050;
  line-height: 1.5;
  word-break: break-all;
}

.feedback-grind {
  font-size: 24rpx;
  font-weight: 800;
  color: #E8752A;
  line-height: 1.5;
  word-break: break-all;
}

.feedback-direction {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx;
  background-color: #FFFFFF;
  border: 2rpx solid rgba(232, 117, 42, 0.28);
  border-radius: 14rpx;
}

.feedback-direction-title {
  font-size: 25rpx;
  font-weight: 800;
  color: #2A211B;
}

.feedback-direction-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.feedback-direction-label {
  flex: 0 0 auto;
  min-width: 68rpx;
  padding: 4rpx 10rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background-color: #FFFAF6;
  color: #E8752A;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.35;
}

.feedback-direction-value {
  flex: 1;
  min-width: 0;
  color: #7A6050;
  font-size: 23rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* 操作按钮 */
.recipe-actions {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background-color: #FAF7F2;
  border: 2rpx solid #EDE5D8;
}

.recipe-action-card {
  width: 48%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  min-height: 96rpx;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #EDE5D8;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(122, 96, 80, 0.08);
}

.action-secondary {
  background-color: #FFFAF6;
  border: 2rpx solid rgba(232, 117, 42, 0.48);
  color: #E8752A;
}

.action-muted {
  background-color: #FAF7F2;
  border: 2rpx solid #EDE5D8;
  color: #7A6050;
}

.action-primary {
  background-color: #3E9A5E;
  border: 2rpx solid rgba(62, 154, 94, 0.22);
  color: #FFFFFF;
  box-shadow: 0 6rpx 16rpx rgba(62, 154, 94, 0.18);
}

.action-primary.disabled {
  opacity: 0.5;
}

.action-label {
  display: block;
  width: 100%;
  color: inherit;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
  word-break: keep-all;
}
